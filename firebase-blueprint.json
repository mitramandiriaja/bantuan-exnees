{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profiles containing roles and login stats",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The registered email address"
        },
        "displayName": {
          "type": "string",
          "description": "The display name of the user"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "user"],
          "description": "The role for role-based access control (RBAC)"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Created timestamp"
        },
        "lastLoginAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last login timestamp"
        }
      },
      "required": ["email", "displayName", "role", "createdAt", "lastLoginAt"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Auditable log of user actions",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user UID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user email"
        },
        "activity": {
          "type": "string",
          "description": "Details of the activity"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Activity occurrence timestamp"
        }
      },
      "required": ["userId", "email", "activity", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Access control and metadata per user"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Auditable log of operations"
    }
  }
}
